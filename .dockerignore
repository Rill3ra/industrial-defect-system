# Large data and results
# (Dockerfile.api / Dockerfile.streamlit копируют только src/ и configs/,
# так что data/ и runs/ в образ и так не попадают — они монтируются как
# volumes в docker-compose.yml. Игнорируем их здесь на всякий случай,
# чтобы даже случайный COPY . не утащил тяжёлые файлы в build-контекст.)
runs/
data/raw/mvtec_ad/
data/splits/

